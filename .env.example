# ─────────────────────────────────────────────────────────
# Microsoft Graph API (OAuth2 Device Code Flow — Public Client)
# Como obter:
#   1. portal.azure.com → Azure Active Directory → App registrations
#   2. Nome: "Hayden Matriculas Bot" | Tipo: Single tenant
#   3. API permissions → Microsoft Graph → Delegated → Mail.Send
#   4. Authentication → Allow public client flows → Yes
#   5. Overview → copie Application ID e Directory (tenant) ID
# Nota: não é necessário Client Secret — o fluxo é Public Client (Device Code).
# ─────────────────────────────────────────────────────────
GRAPH_TENANT_ID=SEU_TENANT_ID_AQUI
GRAPH_CLIENT_ID=SEU_CLIENT_ID_AQUI

# ─────────────────────────────────────────────────────────
# Remetente PRODUÇÃO — e-mails saem dessa conta no modo real
# O usuário faz login com essa conta via OAuth (Device Code Flow)
# ─────────────────────────────────────────────────────────
EMAIL_REMETENTE=luiza@haydencapital.com.br
EMAIL_NOME_REMETENTE=Luiza Nohra | Hayden Capital
EMAIL_CARGO=Legal Counsel
EMAIL_TELEFONE=+55 (11) XXXXX-XXXX

# ─────────────────────────────────────────────────────────
# Remetente TESTE — assinatura e destino no modo teste
# ─────────────────────────────────────────────────────────
EMAIL_REMETENTE_TESTE=felipess@haydencapital.com.br
EMAIL_NOME_REMETENTE_TESTE=Felipe Serra Silva | Hayden Capital
EMAIL_CARGO_TESTE=Summer Intern
EMAIL_TELEFONE_TESTE=+55 (62) XXXXX-XXXX

# Todos os e-mails do modo teste chegam aqui (em vez dos cartórios)
EMAIL_TESTE=felipess@haydencapital.com.br
