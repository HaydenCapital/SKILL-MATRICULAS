# ─────────────────────────────────────────────────────────
# MODO DE ENVIO: "smtp" ou "graph"
# Recomendado para M365 corporativo: "graph"
# ─────────────────────────────────────────────────────────
MODO_ENVIO=graph

# ─────────────────────────────────────────────────────────
# OPÇÃO A — SMTP básico (funciona com App Password ou sem MFA)
# ─────────────────────────────────────────────────────────
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=felipess@haydencapital.com.br
SMTP_PASS=SUA_SENHA_OU_APP_PASSWORD_AQUI

# ─────────────────────────────────────────────────────────
# OPÇÃO B — Microsoft Graph API (OAuth2) — recomendado
# Passos para obter as credenciais:
#   1. Acesse portal.azure.com
#   2. Azure Active Directory → App registrations → New registration
#   3. Nome: "Hayden Matriculas Bot"  |  Tipo: Single tenant
#   4. API permissions → Add → Microsoft Graph → Application → Mail.Send → Grant admin consent
#   5. Certificates & secrets → New client secret → copie o valor
#   6. Overview → copie Application (client) ID e Directory (tenant) ID
# ─────────────────────────────────────────────────────────
GRAPH_TENANT_ID=SEU_TENANT_ID_AQUI
GRAPH_CLIENT_ID=SEU_CLIENT_ID_AQUI
GRAPH_CLIENT_SECRET=SEU_CLIENT_SECRET_AQUI

# ─────────────────────────────────────────────────────────
# CONFIGURAÇÃO GERAL
# ─────────────────────────────────────────────────────────
EMAIL_REMETENTE=felipess@haydencapital.com.br
EMAIL_NOME_REMETENTE=Felipe | Hayden Capital

# Modo teste: envia todos para este endereço em vez dos cartórios reais
# Deixe em branco para disparar de verdade
EMAIL_TESTE=felipess@haydencapital.com.br
